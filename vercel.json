{
  "version": 2,
  "builds": [
    {
      "src": "**/*",
      "use": "@vercel/static"
    }
  ],
  "routes": [
    { "src": "/products", "dest": "/products.html" },
    { "src": "/cart",     "dest": "/cart.html"     },
    { "src": "/checkout", "dest": "/checkout.html" },
    { "src": "/login",    "dest": "/login.html"    },
    { "src": "/register", "dest": "/register.html" },
    { "src": "/success",  "dest": "/success.html"  },
    { "src": "/(.*)",     "dest": "/$1"            }
  ]
}
